{
  "functions": {
    "api/webhook.js": {
      "runtime": "edge"
    },
    "api/callback.js": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api/webhook.js" },
    { "source": "/api/callback", "destination": "/api/callback.js" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/", "destination": "/index.html" }
  ]
}
